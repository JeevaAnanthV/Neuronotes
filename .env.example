# ── Postgres ───────────────────────────────────────────────────────────────────
# Local Docker (docker-compose) connection string:
DATABASE_URL=postgresql+asyncpg://neuronotes:neuronotes@localhost:5432/neuronotes

# Supabase connection string (use this when deploying with Supabase):
# DATABASE_URL=postgresql+asyncpg://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres

# ── Gemini ────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# Model names (defaults shown — override to use a different variant)
CHAT_MODEL=gemini-2.0-flash
EMBEDDING_MODEL=models/text-embedding-004

# ── API Rate Limiting ─────────────────────────────────────────────────────────
# Format: "N/period" where period is second/minute/hour/day
RATE_LIMIT=60/minute

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Use "*" to allow all (not recommended in prod).
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
